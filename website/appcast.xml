        <item>
            <title>Version 1.1.0</title>
            <sparkle:version>2</sparkle:version>
            <sparkle:shortVersionString>1.1.0</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
            <description><![CDATA[
                <h2>Buddy v1.1.0</h2>
                <ul>
                    <li>Real-time delivery via Server-Sent Events — waves, chats, and calls arrive instantly</li>
                    <li>FaceTime calling now works correctly — click Call and it dials your friend directly</li>
                    <li>Owl size picker (Small / Medium / Large) in the menu bar</li>
                    <li>Friend names now visible on dark wallpapers</li>
                    <li>Subtle green dot replaces the large availability glow</li>
                    <li>Chat messages now show in a speech bubble before shrinking to an indicator</li>
                    <li>Wave animation no longer gets clipped</li>
                </ul>
            ]]></description>
            <pubDate>Thu, 27 Mar 2026 20:00:00 +0000</pubDate>
